        <insert tableName="expense_item"><column name="category" value="CASH_OUT"/><column name="amount" valueNumeric="900000"/></insert>
        <insert tableName="expense_item"><column name="category" value="OTHERS"/><column name="amount" valueNumeric="400000"/></insert>
    </changeSet>

    <changeSet id="007-seed-pending-transfer" author="codex">
        <insert tableName="pending_transfer"><column name="transfer_date" valueDate="2025-03-22"/><column name="transfer_type" value="INCOMING"/><column name="counterpart" value="Rabih Sassine"/><column name="amount" valueNumeric="2599"/><column name="status" value="PENDING"/></insert>
